# انسخ هذا الملف إلى .env وعدّل القيم (لا ترفع .env إلى Git)

# --- لوحة الإدارة (/admin) والـ API ---
ADMIN_PASSWORD=admin
JWT_SECRET=ضع_سلسلة_عشوائية_طويلة_وقوية

# --- خادم Express المحلي (اختياري، الافتراضي 3001) ---
PORT=3001

# --- Google Analytics 4 (Data API) — مطلوب للإحصائيات الحقيقية ---
# رقم خاصية GA4 من المسؤول (Admin > Property settings)، مثل: 123456789
GA4_PROPERTY_ID=534867835

# إما مسار ملف JSON لحساب الخدمة على جهازك:
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# أو المحتوى كاملًا كنص (مناسب لـ Netlify / بدون ملف محلي):
# GA_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
